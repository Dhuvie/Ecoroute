# EcoRoute Backend Environment Variables (copy to .env and adjust)

# App
APP_NAME=EcoRoute API
APP_VERSION=1.0.0
DEBUG=True

# Database (use sqlite for dev, postgresql for prod)
# DATABASE_URL=postgresql://ecoroute:ecoroute_secret@localhost:5432/ecoroute
DATABASE_URL=sqlite:///./data/ecoroute.db

# ML model path
MODEL_PATH=ml/models/best_model.joblib

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Analytics / simulation defaults
FUEL_PRICE_PER_LITER=95.0
CO2_COST_PER_KG=0.05
DRIVER_COST_PER_HOUR=250.0

# OSMnx cache
OSMNX_CACHE_DIR=data/osm_cache
